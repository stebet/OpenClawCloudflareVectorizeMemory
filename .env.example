# Replace these placeholders before running the live Cloudflare integration tests.
# Use a disposable or dedicated Vectorize index for pre-publish validation.

OPENCLAW_CF_MEMORY_RUN_LIVE_INTEGRATION=0
CLOUDFLARE_ACCOUNT_ID=replace-with-your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=replace-with-your-cloudflare-api-token
CLOUDFLARE_VECTORIZE_INDEX_NAME=replace-with-your-disposable-vectorize-index
CLOUDFLARE_WORKERS_AI_EMBEDDING_MODEL=@cf/baai/bge-base-en-v1.5
OPENCLAW_CF_MEMORY_TEST_NAMESPACE_PREFIX=cf-memory-live
